<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:Class="ImageFanReloaded.Controls.Security.PasswordEntryWindow"
		Title="Encrypted File Access"
		Width="450" Height="220"
		WindowStartupLocation="CenterOwner"
		CanResize="False"
		Background="#1e1e1e"
		Foreground="#e0e0e0"
		ExtendClientAreaToDecorationsHint="True">
	<Grid RowDefinitions="Auto, *, Auto">
		<Border Grid.Row="0" Height="30" Background="#2d2d2d" VerticalAlignment="Top">
			<TextBlock Text="🛡️ Encrypted File Access"
					   VerticalAlignment="Center"
					   HorizontalAlignment="Left"
					   Margin="10,0,0,0"
					   FontSize="12"
					   Foreground="#aaaaaa" />
		</Border>

		<StackPanel Grid.Row="1" Margin="30,20,30,0" Spacing="15">
			<TextBlock Text="This image is protected by encryption."
					   FontSize="16"
					   FontWeight="SemiBold"
					   Foreground="White" />
			<TextBlock Text="Please enter the password to unlock this session:"
					   FontSize="13"
					   Foreground="#bbbbbb" />
			<TextBox Name="_passwordTextBox"
					 PasswordChar="*"
					 PlaceholderText="Enter Password"
					 VerticalAlignment="Center"
					 Background="#2d2d2d"
					 BorderBrush="#3d3d3d"
					 Foreground="White"
					 KeyDown="OnKeyDown" />
		</StackPanel>

		<Border Grid.Row="2" Background="#1a1a1a" Height="60">
			<StackPanel Orientation="Horizontal"
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						Margin="0,0,20,0"
						Spacing="12">
				<Button Content="Unlock"
						Click="OnOkClick"
						IsDefault="True"
						Width="100"
						Height="32"
						Background="#007acc"
						Foreground="White"
						FontWeight="Bold"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center" />
				<Button Content="Cancel"
						Click="OnCancelClick"
						IsCancel="True"
						Width="100"
						Height="32"
						Background="Transparent"
						BorderBrush="#3d3d3d"
						BorderThickness="1"
						Foreground="#bbbbbb"
						HorizontalContentAlignment="Center"
						VerticalContentAlignment="Center" />
			</StackPanel>
		</Border>
	</Grid>
</Window>
